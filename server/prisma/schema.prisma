// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  username       String         @id
  email          String         @unique
  password       String
  firstName      String
  lastName       String?
  phoneNumber    String         @unique @db.VarChar(20)
  userCategories UserCategory[]
  transactions   Transaction[]
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model Transaction {
  id           Int             @id @default(autoincrement())
  amount       Decimal         @db.Decimal(13, 4)
  description  String?
  date         DateTime
  dateCreated  DateTime        @default(now())
  trxType      TransactionType @relation(fields: [trxTypeId], references: [id])
  currency     MasterCurrency? @relation(fields: [currencyCode], references: [currency_code])
  userCategory UserCategory?   @relation(fields: [categoryId], references: [id])
  user         User            @relation(fields: [username], references: [username])
  trxTypeId    Int
  currencyCode String          @db.Char(3)
  categoryId   Int
  username     String
}

model UserCategory {
  user         User          @relation(fields: [username], references: [username])
  username     String
  id           Int           @id @default(autoincrement())
  name         String
  dateCreated  DateTime      @default(now())
  transactions Transaction[]
}

model TransactionType {
  id           Int           @id @default(autoincrement())
  name         String
  transactions Transaction[]
}

model MasterCurrency {
  currency_code String        @id @db.Char(3)
  country       String
  transactions  Transaction[]
}
